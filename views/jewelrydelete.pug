extends layout
block content
  h1= title
  if (toShow == null)
    h2 No instance to delete
  else
    - let jewelryid = toShow._id
    - let jewelryname = toShow.name
    - let jewelrycost = toShow.cost
    - let jewelrydescription = toShow.description
    - let actionid = "/resource/jewelries/" + jewelryid
    script let actionid = "#{actionid}"
    div
      div.row
        div(class='jewelryAttr mr-3') Jewelry ID is:
        div #{jewelryid}
      div.row
        div(class='jewelryAttr mr-3') Jewelry Name is:
        div #{jewelryname}
      div.row
        div(class='jewelryAttr mr-3') Jewelry Cost is:
        div #{jewelrycost}
      div.row
        div(class='jewelryAttr mr-3') Jewelry Description is:
        div #{jewelrydescription}
    button(class="btn btn-danger m-2" onclick="deleteOnid()") Delete
    button(class="btn btn-secondary m-2" onclick="cancel()") Cancel
  script.
    function cancel() {
      // Go back to the home page for the costume collection
      window.location.href='/costumes'
    }
  script.
    function deleteOnid() {
      console.log("starting delete")
      // delete first
      fetch(actionid, {
        method: 'DELETE' // Don't need a body for the delete
      }).then((resp) => {
        return resp.json(); // or resp.text() or whatever the server sends
      }).then((body) => {
        alert("Delete succeded")
        window.location.href='/costumes'
        // TODO handle body
      }).catch((error) => {
        // TODO handle error
        alert("Delete failed " + error )
      });
    }
