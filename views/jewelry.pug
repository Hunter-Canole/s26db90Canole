extends layout

block content
  h1= title
  - let createDest = `dispatch("/resource/jewelries/create")`
  button.btn.btn-success.mb-3(onclick=createDest) Create New Item
  div.container-fluid
    div(class="row m-1")
      each item in results
        - let destination = `dispatch("/resource/jewelries/update?id=${item._id}")`
        - let detailDest = `dispatch("/resource/jewelries/detail?id=${item._id}")`
        - let deleteDest = `dispatch("/resource/jewelries/delete?id=${item._id}")`
        div.col-sm-2
          h5 #{item.name}
          p Price: #{item.cost}
          p #{item.description}
          button.btn( class="btn-primary ml-1", onclick= destination) Update
          br
          button.btn( class="btn-primary ml-1", onclick= detailDest) Detail
          br
          button.btn( class="btn-primary ml-1", onclick= deleteDest) Delete
  script.
    function dispatch(path){
      window.location.href=path
    }
